  "types": [
    {
      "name": "PoolState",
      "docs": [
        "Shared pool PDA: seeds = [b\"pool\"]. Holds ALL users' SOL. One address for the entire protocol."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "mint_stoken",
            "docs": [
              "Shared sSOL NonTransferable Token-2022 mint."
            ],
            "type": "publicKey"
          },
          {
            "name": "total_deposited",
            "docs": [
              "Total lamports currently held in the pool."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "UserState",
      "docs": [
        "Per-user state PDA: seeds = [b\"user_state\", stoken_ata.key()]. Derived from a random stoken_ata address, NOT from the user's wallet, ensuring the wallet does not appear in private_send accounts."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "stoken_ata",
            "docs": [
              "Random sSOL token account address used as PDA seed."
            ],
            "type": "publicKey"
          },
          {
            "name": "current_ots_hash",
            "docs": [
              "Current tip of the OTS hash chain. Each withdrawal reveals the preimage."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "chain_depth",
            "docs": [
              "Remaining OTS uses. Call refresh_ots when exhausted."
            ],
            "type": "u8"
          },
          {
            "name": "deposited",
            "docs": [
              "Lamports attributed to this user position."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "FunderState",
      "docs": [
        "FunderPDA: seeds = [b\"funder\"]. Holds operational SOL for funding ephemeral wallets used in TX1 of StealthSend."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "admin",
            "docs": [
              "Can withdraw, deposit, and set relayer."
            ],
            "type": "publicKey"
          },
          {
            "name": "relayer",
            "docs": [
              "Can call fund_fresh_relayer and process_queue."
            ],
            "type": "publicKey"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "AirsignEscrow",
      "docs": [
        "AirsignEscrow PDA: seeds = [b\"airsign_escrow\", nonce_hash]. Created by mint_airsign, closed by claim_airsign."
      ],
      "type": {
        "kind": "struct",
        "fields": [
